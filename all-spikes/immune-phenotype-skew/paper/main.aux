\citation{hossain2021}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Immune-phenotype gating across four nested strata of the TNBC trial corpus. Bars: fraction of trials in each stratum assigned to the immunogenic-gated (red) and cold-gated (blue) categories with Wilson 95\% confidence intervals. Boxed labels above each pair show the imm:cold ratio. The ICB-only stratum captures the expected effect of FDA labeling (3.12$\times $). Adding PARPi trials to the non-ICB stratum inverts the ratio (0.72$\times $). In the cleanest stratum (non-ICB and non-PARPi), immunogenic-gating still outnumbers cold-gating 2.00$\times $.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:headline}{{1}{5}{Immune-phenotype gating across four nested strata of the TNBC trial corpus. Bars: fraction of trials in each stratum assigned to the immunogenic-gated (red) and cold-gated (blue) categories with Wilson 95\% confidence intervals. Boxed labels above each pair show the imm:cold ratio. The ICB-only stratum captures the expected effect of FDA labeling (3.12$\times $). Adding PARPi trials to the non-ICB stratum inverts the ratio (0.72$\times $). In the cleanest stratum (non-ICB and non-PARPi), immunogenic-gating still outnumbers cold-gating 2.00$\times $}{figure.1}{}}
